{
	"info": {
		"_postman_id": "unison-api-collection",
		"name": "UNISON Alumni Network API",
		"description": "Comprehensive Postman collection for testing the UNISON Alumni Network NestJS backend.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Send OTP",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"user@uet.edu.pk\",\n    \"type\": \"email_verification\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "{{base_url}}/auth/send-otp"
					}
				},
				{
					"name": "Verify OTP",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"user@uet.edu.pk\",\n    \"otp\": \"123456\",\n    \"type\": \"email_verification\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "{{base_url}}/auth/verify-otp"
					}
				},
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"verified_token\": \"TEMP_TOKEN\",\n    \"name\": \"Ahmed Raza\",\n    \"email\": \"ahmed@uet.edu.pk\",\n    \"password\": \"password123\",\n    \"role\": \"alumni\",\n    \"roll_number\": \"2020-CS-1\",\n    \"degree\": \"BSCS\",\n    \"graduation_year\": 2020\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "{{base_url}}/auth/register"
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.environment.set(\"jwt_token\", jsonData.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"ahmed@uet.edu.pk\",\n    \"password\": \"password123\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "{{base_url}}/auth/login"
					}
				}
			]
		},
		{
			"name": "Admin",
			"item": [
				{
					"name": "Pending Accounts",
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{base_url}}/admin/pending-accounts"
					}
				},
				{
					"name": "Approve Account",
					"request": {
						"method": "PATCH",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"role\": \"alumni\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "{{base_url}}/admin/approve-account/:id"
					}
				},
				{
					"name": "Dashboard Stats",
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{base_url}}/admin/dashboard-stats"
					}
				}
			]
		},
		{
			"name": "Alumni",
			"item": [
				{
					"name": "Get Profile",
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{base_url}}/alumni/profile/:id"
					}
				},
				{
					"name": "Add Work Experience",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"company_name\": \"Systems Ltd\",\n    \"role\": \"Software Engineer\",\n    \"start_date\": \"2021-01-01\",\n    \"is_current\": true,\n    \"employment_type\": \"full-time\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "{{base_url}}/alumni/work-experience"
					}
				},
				{
					"name": "Add Skill",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"skill_name\": \"NestJS\",\n    \"category\": \"Backend\",\n    \"proficiency_level\": \"expert\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "{{base_url}}/alumni/skills"
					}
				}
			]
		},
		{
			"name": "Opportunities",
			"item": [
				{
					"name": "Create Opportunity",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Backend Developer\",\n    \"type\": \"job\",\n    \"description\": \"Looking for NestJS expert\",\n    \"requirements\": \"3+ years exp\",\n    \"location\": \"Lahore\",\n    \"is_remote\": true,\n    \"deadline\": \"2024-12-31\",\n    \"company_name\": \"UET Faisalabad\",\n    \"apply_link\": \"https://example.com\",\n    \"required_skills\": [\"NestJS\", \"Neo4j\"]\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "{{base_url}}/opportunities"
					}
				},
				{
					"name": "List Opportunities",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/opportunities?page=1&limit=10",
							"host": ["{{base_url}}"],
							"path": ["opportunities"],
							"query": [
								{ "key": "page", "value": "1" },
								{ "key": "limit", "value": "10" }
							]
						}
					}
				}
			]
		},
		{
			"name": "Search & Skills",
			"item": [
				{
					"name": "Search Alumni",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/search/alumni?skill=NestJS",
							"host": ["{{base_url}}"],
							"path": ["search", "alumni"],
							"query": [{ "key": "skill", "value": "NestJS" }]
						}
					}
				},
				{
					"name": "Get All Skills",
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{base_url}}/skills/all"
					}
				}
			]
		},
		{
			"name": "Network Science",
			"item": [
				{
					"name": "Network Centrality",
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{base_url}}/network/centrality"
					}
				},
				{
					"name": "Skill Trends",
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{base_url}}/network/skill-trends"
					}
				}
			]
		},
		{
			"name": "Notifications",
			"item": [
				{
					"name": "My Notifications",
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{base_url}}/notifications"
					}
				}
			]
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{jwt_token}}",
				"type": "string"
			}
		]
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [""]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [""]
			}
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:5000/api",
			"type": "string"
		},
		{
			"key": "jwt_token",
			"value": "",
			"type": "string"
		}
	]
}
